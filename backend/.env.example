# ── سکه نامدار · تنظیمات سرور ──────────────────────────────────────────────
# این فایل را به نام  .env  کپی کنید و مقادیر را پر کنید
# cp .env.example .env

# پورت سرور (پیش‌فرض: 3000)
PORT=3000

# رمز JWT — یک رشته تصادفی طولانی بنویسید (مهم!)
JWT_SECRET=your-long-random-secret-here

# نام کاربری و رمز ورود پنل ادمین
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-strong-password-here

# توکن بات تلگرام (از @BotFather بگیرید)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# آی‌دی یا یوزرنیم کانال تلگرام
TELEGRAM_CHANNEL=@your-channel-username
